{
  "name": "zuedocs",
  "version": "0.1.8",
  "description": "Reusable Astro docs template, styles, and client-side docs enhancements for amxv projects.",
  "private": false,
  "type": "module",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/amxv/zuedocs.git"
  },
  "homepage": "https://github.com/amxv/zuedocs#readme",
  "bugs": {
    "url": "https://github.com/amxv/zuedocs/issues"
  },
  "packageManager": "bun@1.3.11",
  "bin": {
    "zuedocs": "./bin/zuedocs.js",
    "create-zuedocs": "./bin/zuedocs.js"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "check": "astro check"
  },
  "dependencies": {
    "mermaid": "^11.16.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.4",
    "@types/node": "^24.0.13",
    "astro": "^7.0.3",
    "typescript": "^5.9.2"
  },
  "files": [
    "bin",
    "src",
    "public",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": "./src/index.ts",
    "./types": "./src/types.ts",
    "./styles.css": "./src/styles/global.css",
    "./docsEnhancements": "./src/scripts/docsEnhancements.ts",
    "./layouts/BaseLayout.astro": "./src/layouts/BaseLayout.astro",
    "./layouts/DocsPageLayout.astro": "./src/layouts/DocsPageLayout.astro",
    "./components/SiteHeader.astro": "./src/components/SiteHeader.astro",
    "./components/SiteFooter.astro": "./src/components/SiteFooter.astro",
    "./package.json": "./package.json"
  }
