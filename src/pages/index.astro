---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { siteConfig } from "../data/docs";

const docs = (await getCollection("docs")).sort((a, b) => a.data.order - b.data.order);

const proofPoints = [
  {
    title: "Credible first contact",
    body: "A homepage that frames your product with intent instead of dropping new readers into a wall of autogenerated API prose."
  },
  {
    title: "Docs collection structure",
    body: "Markdown-backed guides with category grouping, stable routes, and an inline table of contents on every article page."
  },
  {
    title: "Template-safe language",
    body: "Neutral copy blocks, starter navigation, and adaptable content placeholders so the repo is reusable instead of product-locked."
  },
  {
    title: "Shipping notes included",
    body: "Deployment guidance for Vercel, domain wiring through Cloudflare DNS, and a lightweight CI check for pull requests."
  }
];

const audience = [
  "Product teams that want a distinctive docs surface without spending a sprint inventing one from zero.",
  "Founders and engineers who need a branded overview page plus a practical docs hierarchy on day one.",
  "Template maintainers who care about deployment repeatability, clean content conventions, and fast customization."
];
---

<BaseLayout
  title={`${siteConfig.name} | ${siteConfig.strapline}`}
  description={siteConfig.description}
>
  <section class="hero shell">
    <div class="hero__copy">
      <p class="section-label">Reusable Astro docs system</p>
      <h1>
        Publish documentation that feels designed, not merely exported.
      </h1>
      <p class="hero__lede">
        ZueDocs turns the current Gooselake site language into a reusable Astro
        template: calm editorial typography, a disciplined docs information
        architecture, and deployment notes that match a Vercel plus Cloudflare
        workflow.
      </p>
      <p class="hero__annotation">
        Treat this repo like a template chassis. Swap the copy, colors, and docs
        content while keeping the framing, page structure, and production
        mechanics.
      </p>
      <div class="hero__actions">
        <a class="button button--solid" href="/docs/quickstart">Read the quick start</a>
        <a class="button button--ghost" href="/docs">Explore the docs</a>
      </div>
    </div>
    <aside class="hero__panel">
      <p class="hero__panel-label">Template promise</p>
      <ul class="hero__signal-list">
        <li>Keep the visual polish and pacing of the source site without inheriting its product story.</li>
        <li>Use markdown for the docs body while preserving a richer presentation layer around it.</li>
        <li>Ship static output to Vercel and manage the domain with the same Cloudflare DNS workflow already used elsewhere.</li>
      </ul>
      <div class="hero__terminal">
        <span>$ bun run build</span>
        <span>framework: astro / static output</span>
        <span>content: markdown collection / toc routes</span>
        <span>deploy: vercel / cloudflare dns</span>
      </div>
    </aside>
  </section>

  <section class="shell section-grid">
    <div class="section-heading">
      <p class="section-label">What the template gives you</p>
      <h2>An editorial docs shell with a point of view.</h2>
      <p>
        The structure is intentionally simple: one landing page, one docs index,
        one article layout, and a coherent design system. That keeps the template
        easy to bend without collapsing into boilerplate sameness.
      </p>
    </div>
    <div class="proof-grid">
      {proofPoints.map((item) => (
        <article class="proof-card">
          <h3>{item.title}</h3>
          <p>{item.body}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="shell split-section">
    <div>
      <p class="section-label">Who it is for</p>
      <h2>Teams that need docs to feel authored before the product is famous.</h2>
    </div>
    <div class="stack-list">
      {audience.map((item) => (
        <article class="stack-list__item">
          <p>{item}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="shell capability-band">
    <div class="capability-band__intro">
      <p class="section-label">Template surfaces</p>
      <h2>Everything here is meant to be replaced, but nothing here is throwaway.</h2>
    </div>
    <div class="capability-band__grid">
      <div>
        <p class="capability-title">Overview page</p>
        <p>A structured narrative for value proposition, proof points, and docs entry paths.</p>
      </div>
      <div>
        <p class="capability-title">Docs index</p>
        <p>Category-grouped guides that make the content map legible to first-time readers.</p>
      </div>
      <div>
        <p class="capability-title">Article pages</p>
        <p>Sticky navigation, generated table of contents, and readable long-form documentation styles.</p>
      </div>
      <div>
        <p class="capability-title">Operations notes</p>
        <p>Practical guidance for preview deploys, production domains, and contribution checks.</p>
      </div>
    </div>
  </section>

  <section class="shell docs-teaser">
    <div class="section-heading">
      <p class="section-label">Docs map</p>
      <h2>A starter documentation set that shows future maintainers how to extend the site.</h2>
      <p>
        Replace these guides with your own product material, but keep their job
        in mind: orient the reader, explain the structure, and document the
        release path that keeps the site live.
      </p>
    </div>
    <div class="docs-teaser__grid">
      {docs.map((entry) => (
        <a class="docs-teaser__card" href={`/docs/${entry.id}`}>
          <span>{entry.data.category}</span>
          <h3>{entry.data.title}</h3>
          <p>{entry.data.summary ?? entry.data.description}</p>
        </a>
      ))}
    </div>
  </section>
  <section class="shell closing-note">
    <p>
      Build the docs layer once, then spend your time improving the product and
      the writing instead of rebuilding a shell for every launch.
    </p>
  </section>
</BaseLayout>
