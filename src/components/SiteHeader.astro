---
import ThemeToggle from "./ThemeToggle.astro";
import type { PrimaryNavItem, SiteConfig } from "../types";

interface Props {
  primaryNav: PrimaryNavItem[];
  siteConfig: SiteConfig;
}

const { primaryNav, siteConfig } = Astro.props;
const pathname = Astro.url.pathname;
const showDocsMenu = pathname.startsWith("/docs/");
---

<header class="site-header">
  <div class="shell site-header__inner">
    <a class="brand" href="/">
      <span class="brand__eyebrow">{siteConfig.name}</span>
      <span class="brand__title">{siteConfig.strapline}</span>
    </a>
    <div class="site-header__actions">
      {showDocsMenu && (
        <button class="docs-menu-toggle" type="button" data-docs-sidebar-toggle aria-controls="docs-sidebar" aria-expanded="false" aria-label="Open docs menu">
          <svg viewBox="0 0 24 24" focusable="false" aria-hidden="true">
            <path d="M4 7h16" />
            <path d="M4 12h16" />
            <path d="M4 17h16" />
          </svg>
        </button>
      )}
      <nav class="site-nav" aria-label="Primary">
        {primaryNav.map((item) => {
          const active = !item.external && pathname === item.href;
          return (
            <a
              class:list={["site-nav__link", active && "is-active"]}
              href={item.href}
              target={item.external ? "_blank" : undefined}
              rel={item.external ? "noreferrer" : undefined}
            >
              {item.label}
            </a>
          );
        })}
      </nav>
      {siteConfig.themeToggle !== false && <ThemeToggle />}
    </div>
  </div>
</header>
