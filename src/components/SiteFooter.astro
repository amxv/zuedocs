---
import { siteConfig } from "../data/docs";
---

<footer class="site-footer">
  <div class="shell site-footer__inner">
    <div>
      <p class="site-footer__title">{siteConfig.name}</p>
      <p>
        A reusable editorial docs shell for teams that want a credible first
        impression before they start adding product-specific prose.
      </p>
    </div>
    <div>
      <p class="site-footer__title">What ships in the template</p>
      <p>
        Landing page sections, a docs collection, table-of-contents pages,
        starter guidance, and enough deployment notes to ship on Vercel with a
        Cloudflare-managed domain.
      </p>
    </div>
    <div>
      <p class="site-footer__title">Template repo</p>
      <p>
        Adapt the content, point the nav to your repo, and publish the static
        output wherever your docs belong.
      </p>
    </div>
  </div>
</footer>
