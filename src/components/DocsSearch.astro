---
import "@pagefind/component-ui/css";
---

<div class="docs-search" data-docs-search data-pagefind-ignore="all">
  <pagefind-config bundle-path="/pagefind/" excerpt-length="24"></pagefind-config>
  <pagefind-modal-trigger placeholder="Search docs"></pagefind-modal-trigger>
  <pagefind-modal reset-on-close>
    <pagefind-modal-header>
      <pagefind-input placeholder="Search docs"></pagefind-input>
    </pagefind-modal-header>
    <pagefind-modal-body>
      <pagefind-summary default-message="Search titles, guides, and commands"></pagefind-summary>
      <pagefind-results max-sub-results="4"></pagefind-results>
    </pagefind-modal-body>
    <pagefind-modal-footer>
      <pagefind-keyboard-hints></pagefind-keyboard-hints>
    </pagefind-modal-footer>
  </pagefind-modal>
</div>

<script>
  import "@pagefind/component-ui";

  const isSearchShortcut = (event: KeyboardEvent) => {
    return event.key.toLowerCase() === "k" && (event.metaKey || event.ctrlKey) && !event.altKey && !event.shiftKey;
  };

  const isEditableTarget = (target: EventTarget | null) => {
    return target instanceof Element && Boolean(target.closest("input, textarea, select, [contenteditable]:not([contenteditable='false'])"));
  };

  document.addEventListener("keydown", (event) => {
    if (isSearchShortcut(event) && isEditableTarget(event.target)) {
      event.stopImmediatePropagation();
    }
  }, true);

  const syncBodyLock = (dialog: HTMLDialogElement) => {
    document.body.classList.toggle("has-docs-search-open", dialog.open);
  };

  const visibleFocusables = (dialog: HTMLDialogElement) => {
    const selector = "a[href], button:not([disabled]), input:not([disabled]), select:not([disabled]), textarea:not([disabled]), [tabindex]:not([tabindex='-1'])";
    return Array.from(dialog.querySelectorAll<HTMLElement>(selector)).filter((element) => {
      return !element.hidden && element.getClientRects().length > 0;
    });
  };

  const keepTabFocusInDialog = (event: KeyboardEvent, dialog: HTMLDialogElement) => {
    if (event.key !== "Tab" || !dialog.open) return;

    const focusables = visibleFocusables(dialog);
    const first = focusables[0];
    const last = focusables.at(-1);
    if (!first || !last) return;

    if (event.shiftKey && document.activeElement === first) {
      event.preventDefault();
      last.focus();
    } else if (!event.shiftKey && document.activeElement === last) {
      event.preventDefault();
      first.focus();
    }
  };

  customElements.whenDefined("pagefind-modal").then(() => {
    document.querySelectorAll<HTMLElement>("[data-docs-search]").forEach((root) => {
      const dialog = root.querySelector<HTMLDialogElement>("dialog.pf-modal");
      if (!dialog || dialog.dataset.docsSearchReady === "true") return;

      dialog.dataset.docsSearchReady = "true";
      syncBodyLock(dialog);

      const observer = new MutationObserver(() => syncBodyLock(dialog));
      observer.observe(dialog, { attributes: true, attributeFilter: ["open"] });
      dialog.addEventListener("close", () => syncBodyLock(dialog));
      dialog.addEventListener("keydown", (event) => keepTabFocusInDialog(event, dialog));
    });
  });
</script>
