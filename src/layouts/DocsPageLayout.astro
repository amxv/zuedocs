---
interface Props {
  title: string;
  description: string;
  category: string;
}

const { title, description, category } = Astro.props;
---

<section class="docs-hero">
  <p class="section-label">{category}</p>
  <h1>{title}</h1>
  <p>{description}</p>
</section>
<div class="docs-copy">
  <slot />
</div>
