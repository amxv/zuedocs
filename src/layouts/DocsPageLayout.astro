---
import DocsPageActions from "../components/DocsPageActions.astro";

interface Props {
  title: string;
  description: string;
  category: string;
}

const { title, description, category } = Astro.props;
---

<div data-pagefind-body>
  <section class="docs-hero">
    <div class="docs-hero__head">
      <div class="docs-hero__title-block">
        <p class="section-label" data-pagefind-meta="category">{category}</p>
        <h1 data-pagefind-meta="title">{title}</h1>
      </div>
      <DocsPageActions />
    </div>
    <p data-pagefind-meta="description">{description}</p>
  </section>
  <div class="docs-copy">
    <slot />
  </div>
</div>
